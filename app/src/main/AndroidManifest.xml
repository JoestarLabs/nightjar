<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ─────────────────────────────────────────────────── -->
    <!-- Foreground service (timer countdown) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+: specialUse foreground service sub-type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Android 13+: runtime notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Optionally restart a pending timer after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Android 16+: Promoted ongoing notifications (Live Updates / Status Bar Chip) -->
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
    <!-- System overlay permission (Sunset warning mode overlay) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".NightjarApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locale_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nightjar">

        <!-- ── Main Activity ───────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Nightjar"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:theme="@style/Theme.Nightjar"></activity>

        <!-- ── Dependencies Activity ───────────────────────────────────── -->
        <activity
            android:name=".DependenciesActivity"
            android:exported="false"
            android:label="@string/dependencies_title"
            android:theme="@style/Theme.Nightjar"></activity>


        <!-- ── Lock Timer Foreground Service ───────────────────────────── -->
        <!--
            Type: specialUse (Android 14+)
            Use case: runs a countdown timer and locks the screen on completion.
            Declared in Play Console under "Special Use" foreground service type.
        -->
        <service
            android:name=".service.LockTimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Countdown timer that locks the device screen when it expires" />
        </service>

        <!-- ── Device Admin Receiver (lock screen trigger) ─────────────── -->
        <receiver
            android:name=".receiver.LockDeviceAdminReceiver"
            android:description="@string/device_admin_description"
            android:exported="true"
            android:label="@string/device_admin_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_config" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- ── Boot Receiver (resume pending timers after reboot) ──────── -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="false">
            <intent-filter android:priority="100">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>