    <!-- Tillgänglighetstjänst -->
    <string name="accessibility_service_label">Nightjar skärmlås</string>
    <string name="accessibility_service_description">
        Nightjar använder den här behörigheten enbart för att låsa skärmen när timern är slut.
        Appen läser, spelar inte in eller skickar ingen skärminnehåll eller personuppgifter.
        Fingeravtryck och ansigtsigenkänning fungerar fortfarande efter låsning.
    </string>

    <!-- Behörighetsdialoger -->
    <string name="dialog_notification_title">Tillåt aviseringar</string>
    <string name="dialog_notification_body">
        Nightjar behöver visa en beständig avisering medan timern är aktiv
        för att kunna räkna ned tillförlitligt i bakgrunden.
    </string>
    <string name="dialog_accessibility_title">Aktivera skärmlåsåtkomst</string>
    <string name="dialog_accessibility_body">
        För att låsa skärmen när timern slutar behöver Nightjar en speciell behörighet:
        tillgänglighetstjänsten. Den används enbart för att utlösa skärmlåset – inget annat.
        Appen kan inte läsa din skärm eller komma åt dina uppgifter.
        Du skickas till Android-inställningar för att aktivera den.
    </string>
    <string name="dialog_btn_allow">Tillåt</string>
