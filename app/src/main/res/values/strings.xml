    <!-- Accessibility service -->
    <string name="accessibility_service_label">Nightjar Screen Lock</string>
    <string name="accessibility_service_description">
        Nightjar uses this permission only to lock your screen when the timer expires.
        It does not read, record, or transmit any screen content or personal data.
        Your fingerprint and face unlock remain fully functional after locking.
    </string>

    <!-- Permission dialogs -->
    <string name="dialog_notification_title">Allow notifications</string>
    <string name="dialog_notification_body">
        Nightjar needs to show a persistent notification while the timer is running,
        so it can count down reliably in the background.
    </string>
    <string name="dialog_accessibility_title">Enable screen-lock access</string>
    <string name="dialog_accessibility_body">
        To lock your screen when the timer ends, Nightjar needs one special permission:
        the Accessibility Service. This lets the app trigger the lock screen — and nothing else.
        It cannot read your screen or access your data.
        You will be taken to Android Settings to enable it.
    </string>
    <string name="dialog_btn_allow">Allow</string>
